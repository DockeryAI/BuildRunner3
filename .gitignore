# Git worktrees
../br3-*/
.dispatch-worktrees/
.buildrunner/build-reports/
.buildrunner/builds/BUILD_e2e-dispatch-test.md

# Local git backup directory — never commit
.git.remote-backup/

# BR3 runtime state dirs — session logs, dispatch artifacts, queues
# These are generated per-session and must not pollute source history
.buildrunner/codex-dispatch/
.buildrunner/codex-sessions/
.buildrunner/research-queue/
.buildrunner/decisions.log.*
.buildrunner/locks/
.buildrunner/current-phase.json
.buildrunner/orchestration.json
.buildrunner/agents.json
.buildrunner/telemetry.db

# Claude Code runtime lockfiles (not source)
.claude/scheduled_tasks.lock

# BR3 /ship runtime state — sentinel, run logs, metrics fallback
# Written per-run; must not pollute source history
.buildrunner/ship/*.json
.buildrunner/ship/*.jsonl
.buildrunner/ship/*.log

