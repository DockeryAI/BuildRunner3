#!/usr/bin/env bash
# Build Runner 3.0 pre-commit hook
# Regenerates STATUS.md from features.json before each commit

set -euo pipefail

# Only run if Build Runner 3.0 is present
[ -f .buildrunner/features.json ] || exit 0

# Regenerate STATUS.md from features.json
if [ -f .buildrunner/scripts/generate-status.mjs ]; then
  node .buildrunner/scripts/generate-status.mjs
  git add .buildrunner/STATUS.md 2>/dev/null || true
elif [ -f .buildrunner/scripts/generate-status.js ]; then
  node .buildrunner/scripts/generate-status.js
  git add .buildrunner/STATUS.md 2>/dev/null || true
fi

exit 0
