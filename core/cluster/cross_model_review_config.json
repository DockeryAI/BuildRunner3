{
  "backends": {
    "codex": {
      "enabled": true,
      "command": "codex",
      "args": ["exec", "--"],
      "timeout_seconds": 360,
      "priority": 1
    }
  },
  "reviewers": {
    "claude_model": "claude-sonnet-4-6",
    "codex_model": "gpt-5.4"
  },
  "arbiter": {
    "model": "claude-opus-4-7",
    "effort": "xhigh"
  },
  "cache_dir": "~/.buildrunner/cache/cross-reviews"
}
