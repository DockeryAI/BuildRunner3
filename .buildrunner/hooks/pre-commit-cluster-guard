#!/usr/bin/env bash
# BR3 Cluster Guard — pre-commit hook (Phase 7)
#
# Rejects commits that contain direct cluster-node calls, bypassing RuntimeRegistry.execute().
# Forbidden patterns:
#   1. Direct ollama CLI calls outside of OllamaRuntime
#   2. requests.post("http://10.0.1.*")  — raw HTTP to cluster nodes
#   3. curl calls to cluster node IPs (10.0.1.*)
#
# Install: symlink or copy to .git/hooks/pre-commit
# Mirror source: .buildrunner/hooks/pre-commit-cluster-guard

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

VIOLATIONS=0

# Files being committed (staged, Python only — others are noise)
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -z "$STAGED_PY" ]; then
  exit 0
fi

# ---- Pattern 1: bare ollama CLI calls ----------------------------------------
# Allow: core/runtime/ollama_runtime.py (legitimate home of Ollama integration)
# Allow: tests/  (test doubles are OK)
# Reject: anywhere else that spawns ollama directly
OLLAMA_HITS=$(echo "$STAGED_PY" | grep -v '^core/runtime/ollama_runtime\.py' | grep -v '^tests/' | \
  xargs -I{} git show ":{}'" 2>/dev/null | \
  grep -nE '(subprocess\.(run|call|Popen).*\bollama\b|os\.system.*\bollama\b)' || true)
# Note: we check the staged content, not the working tree.
OLLAMA_HITS=""
while IFS= read -r pyfile; do
  case "$pyfile" in
    core/runtime/ollama_runtime.py) continue ;;
    tests/*) continue ;;
  esac
  hits=$(git show ":$pyfile" 2>/dev/null | \
    grep -nE '(subprocess\.(run|call|Popen).*\bollama\b|os\.system.*\bollama\b)' || true)
  if [ -n "$hits" ]; then
    echo -e "${RED}[cluster-guard] BLOCKED:${NC} direct ollama subprocess call in $pyfile"
    echo "$hits" | head -5
    VIOLATIONS=$((VIOLATIONS + 1))
  fi
done <<< "$STAGED_PY"

# ---- Pattern 2: requests.post to cluster node IPs ---------------------------
while IFS= read -r pyfile; do
  case "$pyfile" in
    core/runtime/ollama_runtime.py) continue ;;
    tests/*) continue ;;
  esac
  hits=$(git show ":$pyfile" 2>/dev/null | \
    grep -nE 'requests\.(post|get|put|delete|patch)\s*\(\s*['"'"'"]http://10\.0\.1\.' || true)
  if [ -n "$hits" ]; then
    echo -e "${RED}[cluster-guard] BLOCKED:${NC} direct requests call to cluster node IP in $pyfile"
    echo "$hits" | head -5
    VIOLATIONS=$((VIOLATIONS + 1))
  fi
done <<< "$STAGED_PY"

# ---- Pattern 3: raw curl calls to cluster node IPs --------------------------
while IFS= read -r pyfile; do
  case "$pyfile" in
    tests/*) continue ;;
  esac
  hits=$(git show ":$pyfile" 2>/dev/null | \
    grep -nE '(subprocess|os\.system).*curl.*10\.0\.1\.' || true)
  if [ -n "$hits" ]; then
    echo -e "${RED}[cluster-guard] BLOCKED:${NC} raw curl call to cluster node IP in $pyfile"
    echo "$hits" | head -5
    VIOLATIONS=$((VIOLATIONS + 1))
  fi
done <<< "$STAGED_PY"

if [ "$VIOLATIONS" -gt 0 ]; then
  echo ""
  echo -e "${RED}[cluster-guard] $VIOLATIONS violation(s) found.${NC}"
  echo -e "${YELLOW}Use RuntimeRegistry.execute(task) — the ONLY authorised dispatch path.${NC}"
  echo "See core/runtime/runtime_registry.py and core/runtime/AGENTS.md."
  exit 1
fi

exit 0
