#!/bin/bash
# BuildRunner 3.0 - Complete Pre-Commit Hook
# Automatically runs ALL BR3 systems before every commit
# ENFORCEMENT: This hook CANNOT be bypassed with --no-verify per governance rules
# Last Updated: 2025-11-24

set -e

echo ""
echo "🔍 BuildRunner 3.0 - Complete Pre-Commit Validation"
echo "===================================================="
echo ""

# Get project root
PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT"

# Check if BR3 is available
if ! command -v br &> /dev/null; then
    echo "⚠️  BuildRunner CLI not found in PATH"
    echo "   Running basic validation only..."
    echo ""
    
    # Fallback to basic checks if BR3 not installed globally
    # (This handles projects where BR3 is in local venv)
    
    # Try to activate venv if present
    if [ -f ".venv/bin/activate" ]; then
        source .venv/bin/activate
    elif [ -f "venv/bin/activate" ]; then
        source venv/bin/activate
    fi
    
    # Try again
    if ! command -v br &> /dev/null; then
        echo "❌ Cannot run BR3 checks - CLI not available"
        echo "   Install: pip install buildrunner"
        exit 1
    fi
fi

# Track overall success
ALL_CHECKS_PASSED=true

# Function to run a check
run_check() {
    local name="$1"
    local command="$2"
    
    echo "▶ $name"
    
    if eval "$command" > /tmp/br-check.log 2>&1; then
        echo "  ✅ PASSED"
        return 0
    else
        echo "  ❌ FAILED"
        echo ""
        cat /tmp/br-check.log | head -30
        echo ""
        ALL_CHECKS_PASSED=false
        return 1
    fi
}

# ============================================
# PHASE 1: SECURITY SCANNING
# ============================================
echo "🔒 Phase 1: Security Scanning"
echo "=============================="

run_check "Security Check (Secrets + SQL)" "br security check --staged"

echo ""

# ============================================
# PHASE 2: AUTO-DEBUG PIPELINE (QUICK CHECKS)
# ============================================
echo "🧪 Phase 2: Auto-Debug Pipeline"
echo "==============================="

run_check "BuildRunner Auto-Debug (Quick)" "br autodebug run --skip-deep"

echo ""

# ============================================
# PHASE 3: CODE QUALITY VALIDATION
# ============================================
echo "⭐ Phase 3: Code Quality"
echo "======================="

run_check "Quality Check" "br quality check"

echo ""

# ============================================
# PHASE 4: ARCHITECTURE GUARD
# ============================================
echo "🏗️  Phase 4: Architecture Validation"
echo "===================================="

run_check "Architecture Guard" "br guard check"

echo ""

# ============================================
# PHASE 5: GOVERNANCE ENFORCEMENT
# ============================================
echo "📋 Phase 5: Governance Rules"
echo "============================"

HOOK_REQUIRE_ADVERSARIAL="$HOME/.buildrunner/hooks/require-adversarial-review.sh"
if [ -x "$HOOK_REQUIRE_ADVERSARIAL" ]; then
    run_check "Adversarial Review Enforcement" "\"$HOOK_REQUIRE_ADVERSARIAL\" \"$PROJECT_ROOT\""
else
    echo "  ⚠️  require-adversarial-review.sh not found - skipping"
fi

# Check if governance file exists
if [ -f ".buildrunner/governance/governance.yaml" ]; then
    echo "  ✅ governance.yaml exists"
    # TODO: Implement br governance validate command
else
    echo "  ⚠️  No governance.yaml found - skipping"
fi

echo ""

# ============================================
# FINAL VERDICT
# ============================================
echo "===================================================="

if [ "$ALL_CHECKS_PASSED" = true ]; then
    echo "✅ ALL PRE-COMMIT CHECKS PASSED"
    echo ""
    echo "📊 Systems Validated:"
    echo "   • Security scanning (secrets, SQL injection)"
    echo "   • Auto-debug pipeline (syntax, tests, linting)"
    echo "   • Code quality gates (structure, testing, docs)"
    echo "   • Architecture guard (spec compliance)"
    echo "   • Governance rules (policies, thresholds)"
    echo ""
    echo "✓ Proceeding with commit..."
    exit 0
else
    echo "❌ PRE-COMMIT CHECKS FAILED"
    echo ""
    echo "🚫 COMMIT BLOCKED by BuildRunner Governance"
    echo ""
    echo "Fix the issues above and try again."
    echo ""
    echo "💡 Quick fixes:"
    echo "   • Security issues: Remove sensitive data, parameterize queries"
    echo "   • Test failures: Fix broken tests, add missing tests"
    echo "   • Quality issues: Run 'br quality check --fix' for auto-fixes"
    echo "   • Architecture drift: Update PROJECT_SPEC.md or revert changes"
    echo ""
    echo "📚 Documentation: .buildrunner/governance/governance.yaml"
    exit 1
fi

# ---- BR3 Cluster Guard (Phase 7) ----------------------------------------
# Rejects direct ollama/requests/curl calls to cluster node IPs.
# Use RuntimeRegistry.execute(task) — the ONLY authorised dispatch path.
CLUSTER_GUARD="$(git rev-parse --show-toplevel)/.buildrunner/hooks/pre-commit-cluster-guard"
if [ -x "$CLUSTER_GUARD" ]; then
  bash "$CLUSTER_GUARD" || exit 1
fi
