{
  "sources": {
    "ebay_browse": {
      "enabled": true,
      "marketplace_id": "EBAY_US",
      "limit": 50,
      "condition_filter": null,
      "category_ids": null
    },
    "reddit_rss": {
      "enabled": true,
      "subreddits": ["buildapcsales", "hardwareswap"],
      "limit": 25
    },
    "craigslist_rss": {
      "enabled": true,
      "cities": ["sfbay", "losangeles", "seattle"],
      "cl_category": "sss"
    },
    "pcpartpicker": {
      "enabled": true,
      "use_playwright": false
    }
  },
  "dedup": {
    "url_hash": true,
    "title_similarity": true,
    "similarity_threshold": 0.85
  },
  "pair_detection": {
    "enabled": true,
    "same_seller_window_hours": 72
  },
  "selectors": {
    "ebay.com": {
      "css_selector": ".s-item",
      "title_selector": ".s-item__title",
      "price_selector": ".s-item__price",
      "link_selector": ".s-item__link"
    },
    "newegg.com": {
      "css_selector": ".item-cell",
      "title_selector": ".item-title",
      "price_selector": ".price-current",
      "link_selector": ".item-title"
    },
    "craigslist.org": {
      "css_selector": ".result-row",
      "title_selector": ".result-title",
      "price_selector": ".result-price",
      "link_selector": ".result-title"
    },
    "reddit.com": {
      "css_selector": ".Post",
      "title_selector": "h3",
      "price_selector": null,
      "link_selector": "a"
    }
  }
}
