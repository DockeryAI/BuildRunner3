# .env.example — copy to .env and fill in real values.
# NEVER commit .env to git. See .gitignore.

# Notion Integration
NOTION_SECRET=ntn_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
HOME_PAGE_ID=Projects-XXXXXXXXXXXXXXXXXXXXXXXXXXX
NOTION_PARENT_PAGE_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
NOTION_HOME_PAGE_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-jwt>

# Datadog
DD_API_KEY=<datadog-api-key>
DD_SITE=us5.datadoghq.com
DD_ENV=development
DD_SERVICE=buildrunner
DD_VERSION=3.2.0

# OpenTelemetry
OTEL_SERVICE_NAME=buildrunner
OTEL_TRACES_EXPORTER=datadog
OTEL_METRICS_EXPORTER=datadog
OTEL_LOGS_EXPORTER=datadog

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-<your-openrouter-key>

# Anthropic / Claude Agent SDK
ANTHROPIC_API_KEY=sk-ant-api03-<your-anthropic-key>

# Cluster - Lockwood Intel/Deals API
VITE_INTEL_API_URL=http://10.0.1.101:8100

# eBay Browse API
EBAY_APP_ID=<your-ebay-app-id>
EBAY_CERT_ID=<your-ebay-cert-id>
EBAY_SECRET=<your-ebay-secret>
EBAY_DEV_ID=<your-ebay-dev-id>

# Below (Workhorse) SSH credentials
BELOW_USER=byron
BELOW_PASS=<below-ssh-password>
BELOW_HOST=10.0.1.105

# 17track Delivery Tracking API
TRACK17_API_KEY=<your-17track-api-key>

# Cloudflare API Token (Zone:Edit, DNS:Edit)
CLOUDFLARE_API_TOKEN=<your-cloudflare-api-token>
